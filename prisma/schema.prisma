// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  role         UserRole @default(ADMIN)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

/// Single-tenant restaurant configuration (one row, id = `default`).
model RestaurantSettings {
  id                 String   @id @default("default")
  displayName        String   @default("") @map("display_name")
  logoUrl            String   @default("") @map("logo_url")
  whatsappPhoneE164  String   @map("whatsapp_phone_e164")
  pickupStart        String   @map("pickup_start")
  pickupEnd          String   @map("pickup_end")
  deliveryStart      String   @map("delivery_start")
  deliveryEnd        String   @map("delivery_end")
  billHeader         String   @default("") @map("bill_header")
  billFooter         String   @default("") @map("bill_footer")
  paymentMethodsJson Json     @default("[{\"id\":\"cash\",\"name\":\"Cash\"},{\"id\":\"upi\",\"name\":\"UPI\"},{\"id\":\"mpay\",\"name\":\"Mpay\"}]") @map("payment_methods_json")
  /// POS dine-in floor plan: `{ "tables": [{ "id", "label", "xPct", "yPct", "wPct", "hPct" }] }` (percent of layout box).
  floorPlanJson      Json     @default("{\"tables\":[]}") @map("floor_plan_json")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("restaurant_settings")
}

/// Menu category; optional `parentId` for subcategories (tabs still use top-level names in API).
model Category {
  id        String     @id
  name      String
  /**
   * Public image URL or site path for category tab / headers
   */
  image     String     @default("")
  /**
   * Lucide icon key (see `category-icons.ts`)
   */
  icon      String     @default("")
  parentId  String?    @map("parent_id")
  sortOrder Int        @map("sort_order")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryTree")
  items     MenuItem[]

  @@index([parentId])
  @@map("categories")
}

model MenuGlobalAddon {
  id        String @id
  name      String
  price     Float
  sortOrder Int    @map("sort_order")

  @@map("menu_global_addons")
}

model MenuItem {
  id                String                  @id
  categoryId        String                  @map("category_id")
  name              String
  description       String                  @default("")
  image             String                  @default("")
  isVeg             Boolean                 @default(true) @map("is_veg")
  recommended       Boolean                 @default(false)
  available         Boolean                 @default(true)
  sortOrder         Int                     @default(0) @map("sort_order")
  category          Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variations        MenuItemVariation[]
  addons            MenuItemAddon[]
  recipeVersions    RecipeVersion[]
  vendorSaleLines   VendorSaleLine[]
  sellableToVendors VendorSellableMenuItem?

  @@index([categoryId])
  @@map("menu_items")
}

model MenuItemVariation {
  id        String   @id
  itemId    String   @map("item_id")
  name      String
  price     Float
  sortOrder Int      @map("sort_order")
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("menu_item_variations")
}

/// Per-item add-on. `addonKey` is the stable id from the API (e.g. ia-extra-mint); rows may repeat the same key on different items.
model MenuItemAddon {
  id        String   @id @default(cuid())
  itemId    String   @map("item_id")
  addonKey  String   @map("addon_key")
  name      String
  price     Float
  sortOrder Int      @map("sort_order")
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, addonKey])
  @@index([itemId])
  @@map("menu_item_addons")
}

model MenuCombo {
  id          String               @id
  name        String
  description String               @default("")
  image       String               @default("")
  price       Float
  isVeg       Boolean              @default(true) @map("is_veg")
  available   Boolean              @default(true)
  sortOrder   Int                  @default(0) @map("sort_order")
  components  MenuComboComponent[]

  @@map("menu_combos")
}

model MenuComboComponent {
  id          String    @id @default(cuid())
  comboId     String    @map("combo_id")
  itemId      String    @map("item_id")
  variationId String    @map("variation_id")
  quantity    Int       @default(1)
  sortOrder   Int       @map("sort_order")
  combo       MenuCombo @relation(fields: [comboId], references: [id], onDelete: Cascade)

  @@index([comboId])
  @@map("menu_combo_components")
}

model Customer {
  id          String   @id @default(cuid())
  phoneDigits String   @unique @map("phone_digits")
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("customers")
}

/// Short-lived phone OTP for customer login (hashed code).
model OtpChallenge {
  id          String   @id @default(cuid())
  phoneDigits String   @map("phone_digits")
  codeHash    String   @map("code_hash")
  expiresAt   DateTime @map("expires_at")
  attempts    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phoneDigits, expiresAt])
  @@map("otp_challenges")
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum FulfillmentMode {
  pickup
  delivery
  dine_in
}

enum ScheduleMode {
  asap
  scheduled
}

enum OrderSource {
  website
  pos
}

/// Per-day sequence for display ids like KH-200426001 (IST calendar day).
model OrderCounterDay {
  dayKey  String @id @map("day_key")
  lastSeq Int    @map("last_seq")

  @@map("order_counter_day")
}

model Order {
  id                     String          @id @default(uuid())
  /// Human-readable id, e.g. KH-200426001 (DDMMYY + daily sequence). Unique when set.
  orderRef               String?         @unique @map("order_ref")
  customerId             String          @map("customer_id")
  status                 OrderStatus     @default(PENDING)
  fulfillment            FulfillmentMode
  scheduleMode           ScheduleMode    @map("schedule_mode")
  scheduledAt            DateTime?       @map("scheduled_at")
  address                String          @default("")
  landmark               String          @default("")
  notes                  String          @default("")
  latitude               Float?
  longitude              Float?
  totalMinor             Int             @map("total_minor")
  currency               String          @default("INR")
  messageSentViaWhatsApp Boolean         @default(false) @map("message_sent_via_whatsapp")
  /// Placed from public site vs admin POS — notifications only for website.
  source                 OrderSource     @default(website) @map("order_source")
  /// POS payment method key (matches configured payment method id), e.g. cash, upi
  paymentMethod          String          @default("") @map("payment_method")
  /// Dine-in table label at order time (POS); empty for pickup/delivery or legacy dine-in.
  dineInTable            String          @default("") @map("dine_in_table") @db.VarChar(80)
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  customer            Customer                    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines               OrderLine[]
  inventoryMovements  InventoryMovement[]
  batchConsumptions   InventoryBatchConsumption[]
  personalUseEntries  PersonalUseEntry[]
  /// Set when POS / web sale stock deduction succeeded for this order.
  inventoryDeductedAt DateTime?                   @map("inventory_deducted_at")
  /// Set when cancelled-order stock restoration ran (if enabled).
  inventoryRestoredAt DateTime?                   @map("inventory_restored_at")

  @@index([customerId])
  @@index([createdAt])
  @@map("orders")
}

model OrderLine {
  id        String @id @default(cuid())
  orderId   String @map("order_id")
  sortIndex Int    @map("sort_index")
  payload   Json

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_lines")
}

// ---------------------------------------------------------------------------
// Inventory, procurement, recipes (base-unit stock; amounts in paise)
// ---------------------------------------------------------------------------

enum InventoryCostingMethod {
  WEIGHTED_AVERAGE
  LATEST_PURCHASE
}

enum PurchasePaymentType {
  CASH
  CHEQUE
  CREDIT
}

enum SupplierLedgerKind {
  PURCHASE_DEBIT
  PAYMENT_CREDIT
  RETURN_CREDIT
}

enum VendorSalePaymentType {
  CASH
  CREDIT
}

enum VendorLedgerKind {
  SALE_DEBIT
  PAYMENT_CREDIT
}

enum InventoryMovementType {
  OPENING_STOCK
  PURCHASE_RECEIPT
  PURCHASE_RETURN
  POS_OR_WEB_SALE
  VENDOR_SALE
  ORDER_CANCEL_RESTORE
  ADJUSTMENT_UP
  ADJUSTMENT_DOWN
  AUDIT_SURPLUS
  AUDIT_SHORTAGE
  WASTAGE
}

enum InventoryBatchSourceType {
  OPENING_STOCK
  PURCHASE_LINE
  ADJUSTMENT_UP
  AUDIT_SURPLUS
}

enum AdjustmentReason {
  DAMAGE
  CORRECTION
  THEFT
  AUDIT_MISMATCH
  OTHER
}

enum WastageType {
  SPOILAGE
  PREPARATION
  OVERPRODUCTION
  OTHER
}

/// Single-tenant row id = `default`.
model InventorySettings {
  id                   String                 @id @default("default")
  costingMethod        InventoryCostingMethod @default(WEIGHTED_AVERAGE) @map("costing_method")
  restoreStockOnCancel Boolean                @default(true) @map("restore_stock_on_cancel")
  allowNegativeStock   Boolean                @default(true) @map("allow_negative_stock")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  @@map("inventory_settings")
}

model InventoryItem {
  id                       String   @id @default(cuid())
  name                     String
  category                 String   @default("")
  baseUnit                 String   @map("base_unit") @db.VarChar(32)
  purchaseUnit             String   @map("purchase_unit") @db.VarChar(32)
  /// Multiply purchase qty by this to get base units (e.g. kg → g: 1000).
  baseUnitsPerPurchaseUnit Decimal  @map("base_units_per_purchase_unit") @db.Decimal(24, 8)
  stockOnHandBase          Decimal  @default(0) @map("stock_on_hand_base") @db.Decimal(24, 8)
  minStockBase             Decimal  @default(0) @map("min_stock_base") @db.Decimal(24, 8)
  /// Moving average ingredient cost: paise per 1 base unit (decimal for sub-paise precision).
  avgCostPaisePerBase      Decimal  @default(0) @map("avg_cost_paise_per_base") @db.Decimal(24, 6)
  lastPurchasePaisePerBase Decimal  @default(0) @map("last_purchase_paise_per_base") @db.Decimal(24, 6)
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  purchaseLines      PurchaseLine[]
  returnLines        PurchaseReturnLine[]
  batches            InventoryBatch[]
  movements          InventoryMovement[]
  batchConsumptions  InventoryBatchConsumption[]
  recipeIngredients  RecipeIngredient[]
  wastageRows        WastageEntry[]
  stockAdjustments   StockAdjustment[]
  stockAuditLines    StockAuditLine[]
  personalUseEntries PersonalUseEntry[]

  @@index([name])
  @@map("inventory_items")
}

model Supplier {
  id                String   @id @default(cuid())
  name              String
  phone             String   @default("") @db.VarChar(32)
  email             String   @default("") @db.VarChar(120)
  address           String   @default("") @db.Text
  defaultCreditDays Int?     @map("default_credit_days")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  purchases       Purchase[]
  ledgerEntries   SupplierLedgerEntry[]
  payments        SupplierPayment[]
  purchaseReturns PurchaseReturn[]

  @@map("suppliers")
}

model SupplierLedgerEntry {
  id            String             @id @default(cuid())
  supplierId    String             @map("supplier_id")
  occurredAt    DateTime           @default(now()) @map("occurred_at")
  kind          SupplierLedgerKind @map("kind")
  debitPaise    Int                @default(0) @map("debit_paise")
  creditPaise   Int                @default(0) @map("credit_paise")
  referenceType String             @map("reference_type") @db.VarChar(32)
  referenceId   String             @map("reference_id")
  note          String             @default("")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@index([supplierId, occurredAt])
  @@map("supplier_ledger_entries")
}

model Purchase {
  id              String              @id @default(cuid())
  batchRef        String              @unique @map("batch_ref") @db.VarChar(40)
  supplierId      String              @map("supplier_id")
  purchasedAt     DateTime            @map("purchased_at")
  paymentType     PurchasePaymentType @map("payment_type")
  creditDays      Int?                @map("credit_days")
  dueAt           DateTime?           @map("due_at")
  totalPaise      Int                 @map("total_paise")
  notes           String              @default("")
  createdByUserId String?             @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at")

  supplier Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  lines    PurchaseLine[]
  returns  PurchaseReturn[]

  @@index([supplierId, purchasedAt])
  @@map("purchases")
}

model PurchaseLine {
  id                       String    @id @default(cuid())
  purchaseId               String    @map("purchase_id")
  inventoryItemId          String    @map("inventory_item_id")
  qtyPurchase              Decimal   @map("qty_purchase") @db.Decimal(24, 8)
  ratePaisePerPurchaseUnit Int       @map("rate_paise_per_purchase_unit")
  lineTotalPaise           Int       @map("line_total_paise")
  qtyBaseReceived          Decimal   @map("qty_base_received") @db.Decimal(24, 8)
  expiryDate               DateTime? @map("expiry_date")
  lotCode                  String    @default("") @map("lot_code") @db.VarChar(64)

  purchase Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item     InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  batch    InventoryBatch?

  @@index([purchaseId])
  @@index([inventoryItemId])
  @@map("purchase_lines")
}

model InventoryBatch {
  id               String                   @id @default(cuid())
  inventoryItemId  String                   @map("inventory_item_id")
  receivedAt       DateTime                 @map("received_at")
  sourceType       InventoryBatchSourceType @map("source_type")
  sourceId         String                   @map("source_id") @db.VarChar(64)
  /// Nullable: some batches (opening/adjustment) may not have an expiry.
  expiryDate       DateTime?                @map("expiry_date")
  lotCode          String                   @default("") @map("lot_code") @db.VarChar(64)
  qtyReceivedBase  Decimal                  @map("qty_received_base") @db.Decimal(24, 8)
  remainingQtyBase Decimal                  @map("remaining_qty_base") @db.Decimal(24, 8)
  createdAt        DateTime                 @default(now()) @map("created_at")
  purchaseLineId   String?                  @unique @map("purchase_line_id")

  item                InventoryItem               @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  purchaseLine        PurchaseLine?               @relation(fields: [purchaseLineId], references: [id], onDelete: SetNull)
  consumptions        InventoryBatchConsumption[]
  purchaseReturnLines PurchaseReturnLine[]

  @@index([inventoryItemId, receivedAt])
  @@index([expiryDate])
  @@map("inventory_batches")
}

model InventoryBatchConsumption {
  id              String   @id @default(cuid())
  batchId         String   @map("batch_id")
  inventoryItemId String   @map("inventory_item_id")
  orderId         String?  @map("order_id")
  referenceType   String   @map("reference_type") @db.VarChar(32)
  referenceId     String   @map("reference_id") @db.VarChar(64)
  occurredAt      DateTime @map("occurred_at")
  qtyBase         Decimal  @map("qty_base") @db.Decimal(24, 8)
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  batch InventoryBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)
  item  InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  order Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId, occurredAt])
  @@index([orderId])
  @@index([referenceType, referenceId])
  @@map("inventory_batch_consumptions")
}

model PurchaseReturn {
  id               String   @id @default(cuid())
  supplierId       String   @map("supplier_id")
  purchaseId       String?  @map("purchase_id")
  returnedAt       DateTime @map("returned_at")
  totalCreditPaise Int      @map("total_credit_paise")
  notes            String   @default("")
  createdByUserId  String?  @map("created_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  supplier Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchase Purchase?            @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  lines    PurchaseReturnLine[]

  @@index([supplierId])
  @@map("purchase_returns")
}

model PurchaseReturnLine {
  id               String  @id @default(cuid())
  returnId         String  @map("return_id")
  inventoryItemId  String  @map("inventory_item_id")
  inventoryBatchId String? @map("inventory_batch_id")
  qtyPurchase      Decimal @map("qty_purchase") @db.Decimal(24, 8)
  qtyBase          Decimal @map("qty_base") @db.Decimal(24, 8)
  creditPaise      Int     @map("credit_paise")

  purchaseReturn PurchaseReturn  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  item           InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  batch          InventoryBatch? @relation(fields: [inventoryBatchId], references: [id], onDelete: SetNull)

  @@index([returnId])
  @@index([inventoryBatchId])
  @@map("purchase_return_lines")
}

model SupplierPayment {
  id              String   @id @default(cuid())
  supplierId      String   @map("supplier_id")
  paidAt          DateTime @map("paid_at")
  amountPaise     Int      @map("amount_paise")
  method          String   @db.VarChar(32)
  reference       String   @default("") @map("reference") @db.VarChar(120)
  note            String   @default("")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@index([supplierId, paidAt])
  @@map("supplier_payments")
}

model Vendor {
  id                String   @id @default(cuid())
  name              String
  phone             String   @default("") @db.VarChar(32)
  email             String   @default("") @db.VarChar(120)
  address           String   @default("") @db.Text
  defaultCreditDays Int?     @map("default_credit_days")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  sales         VendorSale[]
  ledgerEntries VendorLedgerEntry[]
  payments      VendorPayment[]

  @@map("vendors")
}

model VendorSale {
  id              String                @id @default(cuid())
  vendorId        String                @map("vendor_id")
  soldAt          DateTime              @map("sold_at")
  paymentType     VendorSalePaymentType @map("payment_type")
  creditDays      Int?                  @map("credit_days")
  dueAt           DateTime?             @map("due_at")
  totalPaise      Int                   @map("total_paise")
  notes           String                @default("")
  createdByUserId String?               @map("created_by_user_id")
  createdAt       DateTime              @default(now()) @map("created_at")

  vendor Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  lines  VendorSaleLine[]

  @@index([vendorId, soldAt])
  @@map("vendor_sales")
}

model VendorSaleLine {
  id               String  @id @default(cuid())
  vendorSaleId     String  @map("vendor_sale_id")
  menuItemId       String  @map("menu_item_id")
  variationId      String  @map("variation_id") @db.VarChar(64)
  quantity         Decimal @map("quantity") @db.Decimal(24, 8)
  ratePaisePerUnit Int     @map("rate_paise_per_unit")
  lineTotalPaise   Int     @map("line_total_paise")

  sale     VendorSale @relation(fields: [vendorSaleId], references: [id], onDelete: Cascade)
  menuItem MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([vendorSaleId])
  @@index([menuItemId])
  @@map("vendor_sale_lines")
}

model VendorSellableMenuItem {
  id         String   @id @default(cuid())
  menuItemId String   @unique @map("menu_item_id")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([active])
  @@map("vendor_sellable_menu_items")
}

model VendorPayment {
  id              String   @id @default(cuid())
  vendorId        String   @map("vendor_id")
  paidAt          DateTime @map("paid_at")
  amountPaise     Int      @map("amount_paise")
  method          String   @db.VarChar(32)
  reference       String   @default("") @map("reference") @db.VarChar(120)
  note            String   @default("")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  @@index([vendorId, paidAt])
  @@map("vendor_payments")
}

model VendorLedgerEntry {
  id            String           @id @default(cuid())
  vendorId      String           @map("vendor_id")
  occurredAt    DateTime         @default(now()) @map("occurred_at")
  kind          VendorLedgerKind @map("kind")
  debitPaise    Int              @default(0) @map("debit_paise")
  creditPaise   Int              @default(0) @map("credit_paise")
  referenceType String           @map("reference_type") @db.VarChar(32)
  referenceId   String           @map("reference_id") @db.VarChar(64)
  note          String           @default("")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  @@index([vendorId, occurredAt])
  @@map("vendor_ledger_entries")
}

model RecipeVersion {
  id            String   @id @default(cuid())
  menuItemId    String   @map("menu_item_id")
  /// When null, applies to every variation unless a variation-specific version exists.
  variationId   String?  @map("variation_id") @db.VarChar(64)
  effectiveFrom DateTime @map("effective_from")
  label         String   @default("") @db.VarChar(120)
  createdAt     DateTime @default(now()) @map("created_at")

  menuItem    MenuItem           @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@index([menuItemId, effectiveFrom])
  @@map("recipe_versions")
}

model RecipeIngredient {
  id              String  @id @default(cuid())
  recipeVersionId String  @map("recipe_version_id")
  inventoryItemId String  @map("inventory_item_id")
  qtyBase         Decimal @map("qty_base") @db.Decimal(24, 8)

  recipe RecipeVersion @relation(fields: [recipeVersionId], references: [id], onDelete: Cascade)
  item   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([recipeVersionId, inventoryItemId])
  @@map("recipe_ingredients")
}

model InventoryMovement {
  id              String                @id @default(cuid())
  inventoryItemId String                @map("inventory_item_id")
  occurredAt      DateTime              @default(now()) @map("occurred_at")
  type            InventoryMovementType
  qtyDeltaBase    Decimal               @map("qty_delta_base") @db.Decimal(24, 8)
  referenceType   String                @default("") @map("reference_type") @db.VarChar(32)
  referenceId     String                @default("") @map("reference_id")
  orderId         String?               @map("order_id")
  note            String                @default("")
  createdByUserId String?               @map("created_by_user_id")

  item  InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  order Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId, occurredAt])
  @@index([orderId])
  @@map("inventory_movements")
}

model StockAdjustment {
  id              String           @id @default(cuid())
  inventoryItemId String           @map("inventory_item_id")
  occurredAt      DateTime         @map("occurred_at")
  direction       String           @db.VarChar(8) // "IN" | "OUT" (enforced in app logic)
  qtyBase         Decimal          @map("qty_base") @db.Decimal(24, 8)
  reason          AdjustmentReason @map("reason")
  note            String           @default("") @db.Text
  createdByUserId String?          @map("created_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")

  item InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, occurredAt])
  @@map("stock_adjustments")
}

model WastageEntry {
  id              String      @id @default(cuid())
  inventoryItemId String      @map("inventory_item_id")
  wastedAt        DateTime    @map("wasted_at")
  qtyBase         Decimal     @map("qty_base") @db.Decimal(24, 8)
  wastageType     WastageType @map("wastage_type")
  note            String      @default("")
  createdByUserId String?     @map("created_by_user_id")
  createdAt       DateTime    @default(now()) @map("created_at")

  item InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, wastedAt])
  @@map("wastage_entries")
}

model StockAudit {
  id              String   @id @default(cuid())
  auditedAt       DateTime @map("audited_at")
  note            String   @default("")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  lines StockAuditLine[]

  @@map("stock_audits")
}

model StockAuditLine {
  id                 String  @id @default(cuid())
  stockAuditId       String  @map("stock_audit_id")
  inventoryItemId    String  @map("inventory_item_id")
  countedBase        Decimal @map("counted_base") @db.Decimal(24, 8)
  systemBaseSnapshot Decimal @map("system_base_snapshot") @db.Decimal(24, 8)
  varianceBase       Decimal @map("variance_base") @db.Decimal(24, 8)

  audit StockAudit    @relation(fields: [stockAuditId], references: [id], onDelete: Cascade)
  item  InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([stockAuditId])
  @@map("stock_audit_lines")
}

/// IST calendar day sequence for purchase `batch_ref` (INV-DDMMYY###).
model PurchaseCounterDay {
  dayKey  String @id @map("day_key")
  lastSeq Int    @map("last_seq")

  @@map("purchase_counter_day")
}

// ---------------------------------------------------------------------------
// Payroll / staff management (monthly salary + attendance + advances)
// ---------------------------------------------------------------------------

enum EmployeeDocumentKind {
  ID_PROOF
  ADDRESS_PROOF
  CONTRACT
  OTHER
}

enum AttendanceKind {
  WORKED
  LEAVE
  ABSENT
  WORKED_ON_LEAVE
}

enum AdvanceMethod {
  CASH
  RECHARGE
  OTHER
}

// ---------------------------------------------------------------------------
// Expenses (business) + personal use (cash/stock/order)
// ---------------------------------------------------------------------------

enum ExpenseCategoryGroup {
  RAW_MATERIAL
  BILLS
  OTHER
}

enum PersonalUseKind {
  CASH
  STOCK
  ORDER
  OTHER
}

model ExpenseCategory {
  id        String               @id @default(cuid())
  name      String               @unique @db.VarChar(80)
  group     ExpenseCategoryGroup @default(OTHER)
  active    Boolean              @default(true)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  expenses ExpenseEntry[]

  @@index([active, name])
  @@map("expense_categories")
}

model ExpenseEntry {
  id          String   @id @default(cuid())
  categoryId  String   @map("category_id")
  occurredAt  DateTime @map("occurred_at")
  amountPaise Int      @map("amount_paise")
  note        String   @default("") @db.VarChar(500)
  createdById String?  @map("created_by_user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([occurredAt])
  @@index([categoryId, occurredAt])
  @@map("expense_entries")
}

model PersonalUseEntry {
  id              String          @id @default(cuid())
  kind            PersonalUseKind
  occurredAt      DateTime        @map("occurred_at")
  cashAmountPaise Int             @default(0) @map("cash_amount_paise")
  inventoryItemId String?         @map("inventory_item_id")
  qtyBase         Decimal?        @map("qty_base") @db.Decimal(24, 8)
  orderId         String?         @map("order_id")
  note            String          @default("") @db.VarChar(500)
  createdById     String?         @map("created_by_user_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  item  InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  order Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([kind, occurredAt])
  @@index([inventoryItemId, occurredAt])
  @@index([orderId])
  @@map("personal_use_entries")
}

model Employee {
  id                 String    @id @default(cuid())
  code               String    @default("") @db.VarChar(32)
  name               String    @db.VarChar(120)
  phone              String    @default("") @db.VarChar(32)
  address            String    @default("") @db.Text
  joinedAt           DateTime? @map("joined_at")
  active             Boolean   @default(true)
  monthlySalaryPaise Int       @map("monthly_salary_paise")
  dailyRatePaise     Int       @map("daily_rate_paise")
  paidLeavesPerMonth Int       @default(4) @map("paid_leaves_per_month")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  documents  EmployeeDocument[]
  attendance AttendanceDay[]
  advances   EmployeeAdvance[]
  payroll    PayrollEmployeeLine[]

  @@index([active, name])
  @@index([code])
  @@map("employees")
}

model EmployeeDocument {
  id         String               @id @default(cuid())
  employeeId String               @map("employee_id")
  kind       EmployeeDocumentKind @map("kind")
  title      String               @default("") @db.VarChar(120)
  fileUrl    String               @default("") @map("file_url") @db.VarChar(500)
  note       String               @default("")
  createdAt  DateTime             @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, kind])
  @@map("employee_documents")
}

model AttendanceDay {
  id          String         @id @default(cuid())
  employeeId  String         @map("employee_id")
  dayKey      String         @map("day_key") @db.VarChar(10) // YYYY-MM-DD (local)
  kind        AttendanceKind @map("kind")
  note        String         @default("")
  createdById String?        @map("created_by_user_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayKey])
  @@index([dayKey])
  @@map("attendance_days")
}

model EmployeeAdvance {
  id          String        @id @default(cuid())
  employeeId  String        @map("employee_id")
  occurredAt  DateTime      @map("occurred_at")
  amountPaise Int           @map("amount_paise")
  method      AdvanceMethod @map("method")
  reference   String        @default("") @db.VarChar(120)
  note        String        @default("")
  createdById String?       @map("created_by_user_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, occurredAt])
  @@map("employee_advances")
}

model PayrollRun {
  id          String   @id @default(cuid())
  monthKey    String   @unique @map("month_key") @db.VarChar(7) // YYYY-MM
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by_user_id")

  lines PayrollEmployeeLine[]

  @@map("payroll_runs")
}

model PayrollEmployeeLine {
  id                 String   @id @default(cuid())
  payrollRunId       String   @map("payroll_run_id")
  employeeId         String   @map("employee_id")
  monthlySalaryPaise Int      @map("monthly_salary_paise")
  dailyRatePaise     Int      @map("daily_rate_paise")
  paidLeavesAllowed  Int      @map("paid_leaves_allowed")
  workedDays         Int      @map("worked_days")
  leaveDays          Int      @map("leave_days")
  absentDays         Int      @map("absent_days")
  workedOnLeaveDays  Int      @map("worked_on_leave_days")
  extrasPaise        Int      @map("extras_paise")
  deductionsPaise    Int      @map("deductions_paise")
  advancesPaise      Int      @map("advances_paise")
  netPayPaise        Int      @map("net_pay_paise")
  createdAt          DateTime @default(now()) @map("created_at")

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
  @@map("payroll_employee_lines")
}
